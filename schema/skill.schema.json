{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://magehub.dev/schema/skill.schema.json",
  "type": "object",
  "required": ["id", "name", "version", "category", "description"],
  "oneOf": [
    { "required": ["instructions"] },
    { "required": ["instructions_file"] }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "maxLength": 60
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "category": {
      "type": "string",
      "enum": [
        "module",
        "api",
        "admin",
        "frontend",
        "hyva",
        "testing",
        "performance",
        "upgrade",
        "devops",
        "standards"
      ]
    },
    "description": {
      "type": "string",
      "maxLength": 200
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "magento_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "instructions": {
      "type": "string"
    },
    "instructions_file": {
      "type": "string"
    },
    "conventions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule"],
        "properties": {
          "rule": {
            "type": "string"
          },
          "example": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "oneOf": [{ "required": ["code"] }, { "required": ["code_file"] }],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "code_file": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "anti_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "problem"],
        "properties": {
          "pattern": {
            "type": "string"
          },
          "problem": {
            "type": "string"
          },
          "solution": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string"
          },
          "template": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "compatibility": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude", "opencode", "codex", "qoder"]
      }
    }
  },
  "additionalProperties": false
}
